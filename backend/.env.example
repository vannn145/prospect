PORT=4000
CORS_ORIGIN=http://localhost:5173

# Auth
AUTH_USERNAME=joao
AUTH_PASSWORD=17283910
AUTH_JWT_SECRET=troque_este_segredo
AUTH_TOKEN_EXPIRES_IN=7d

# Banco
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=prospect
PGSSL=false

# Alternativa única para conexão
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prospect

# Google Places API
GOOGLE_PLACES_API_KEY=

# Regras do detector de site
SITE_TIMEOUT_MS=7000
SITE_SLOW_THRESHOLD_MS=4000

# Busca Instagram
INSTAGRAM_SEARCH_TIMEOUT_MS=8000

# Meta WhatsApp Cloud API
META_WHATSAPP_API_VERSION=v22.0
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_VERIFY_TOKEN=troque_token_webhook
META_WHATSAPP_DEFAULT_COUNTRY_CODE=55
META_WHATSAPP_DEFAULT_MODE=template
META_WHATSAPP_TEMPLATE_NAME=saudacao_oficial
META_WHATSAPP_TEMPLATE_LANGUAGE_CODE=pt_BR
META_WHATSAPP_ALLOW_BR_LANDLINE=false
META_WHATSAPP_TEMPLATE_BY_CATEGORY=dentist:saudacao_dentista,lawyer:saudacao_advogado,restaurant:saudacao_restaurante
META_WHATSAPP_USE_TEXT_IN_OPEN_WINDOW=true
META_WHATSAPP_OPEN_WINDOW_LOOKBACK_HOURS=24
META_WHATSAPP_OPEN_WINDOW_TEXT=Olá, tudo bem?\n\nEncontrei sua empresa no Google e percebi que vocês ainda não possuem um site profissional ou presença digital forte.\n\nHoje muitas empresas estão recebendo novos clientes através do Google e do WhatsApp.\n\nTrabalho com criação de sites rápidos e integrados ao WhatsApp que ajudam empresas a aparecer mais no Google e gerar mais clientes.\n\nSe quiser posso te mostrar um exemplo de site para o seu segmento.
META_WHATSAPP_POST_SEND_WAIT_MS=30000
META_WHATSAPP_POST_SEND_POLL_MS=1500
META_WHATSAPP_AUTO_RETRY_ON_INBOUND_ENABLED=true
META_WHATSAPP_AUTO_RETRY_FAILED_CODES=131049
META_WHATSAPP_AUTO_RETRY_LOOKBACK_HOURS=168
META_WHATSAPP_TIMEOUT_MS=15000
META_WHATSAPP_BLOCK_ON_FAILED_ENABLED=true
META_WHATSAPP_BLOCK_ON_FAILED_CODES=131026,130472
META_WHATSAPP_BLOCK_FAILED_LOOKBACK_DAYS=30

# Campanha de e-mail (SMTP Hostinger)
OUTREACH_FROM_EMAIL=contato@impulsestrategy.com.br
OUTREACH_SMTP_HOST=smtp.hostinger.com
OUTREACH_SMTP_PORT=465
OUTREACH_SMTP_SECURE=true
OUTREACH_SMTP_USER=contato@impulsestrategy.com.br
OUTREACH_SMTP_PASS=
OUTREACH_EMAIL_REPLY_TO=
OUTREACH_EMAIL_SEND_DRY_RUN=false
OUTREACH_EMAIL_SEND_DELAY_MS=1200
OUTREACH_EMAIL_SEND_MAX=0

# Inbox de e-mail (IMAP)
OUTREACH_IMAP_HOST=imap.hostinger.com
OUTREACH_IMAP_PORT=993
OUTREACH_IMAP_SECURE=true
OUTREACH_IMAP_USER=contato@impulsestrategy.com.br
# Se vazio, usa OUTREACH_SMTP_PASS
OUTREACH_IMAP_PASS=

# Automação opcional
AUTO_SEARCH_CITIES=Campinas
AUTO_SEARCH_CATEGORIES=dentist,lawyer,restaurant
AUTO_SEARCH_RADIUS=5000
AUTO_SEARCH_MAX_PAGES=3
AUTO_SEARCH_INSTAGRAM=false
